{
  "name": "arqzero",
  "version": "2.0.0",
  "description": "ArqZero — terminal-native AI engineering agent with structured methodologies. Bring your own LLM key.",
  "type": "module",
  "bin": {
    "arqzero": "./bin/arqzero.mjs"
  },
  "scripts": {
    "dev": "tsx bin/arq.ts",
    "build": "tsc",
    "test": "node --test --experimental-strip-types src/**/*.test.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "coding-assistant",
    "cli",
    "terminal",
    "tui",
    "llm",
    "claude",
    "openai",
    "fireworks",
    "anthropic",
    "openrouter",
    "ollama",
    "byok",
    "tdd",
    "agent",
    "subagent",
    "developer-tools",
    "arqzero"
  ],
  "files": [
    "bin/",
    "src/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "!**/*.test.ts"
  ],
  "engines": {
    "node": ">=18.19.0"
  },
  "homepage": "https://github.com/LuciferDono/ArqZero#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LuciferDono/ArqZero.git"
  },
  "bugs": {
    "url": "https://github.com/LuciferDono/ArqZero/issues",
