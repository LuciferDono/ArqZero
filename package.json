    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "openai": "^6.32.0",
    "react": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14"
  }
