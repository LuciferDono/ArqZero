{
  "name": "arqzero",
  "version": "2.0.0",
  "description": "ArqZero — terminal-native AI engineering agent with structured methodologies",
  "type": "module",
  "bin": {
    "arqzero": "./bin/arqzero.mjs"
  },
  "scripts": {
    "dev": "tsx bin/arq.ts",
    "build": "tsc",
    "test": "node --test --experimental-strip-types src/**/*.test.ts"
  },
  "keywords": [
    "cli",
    "ai",
    "coding-assistant",
    "coding-agent",
    "arqzero",
    "terminal"
  ],
  "files": [
    "bin/",
    "src/",
    "!**/*.test.ts"
  ],
  "engines": {
    "node": ">=18.19.0"
  },
  "homepage": "https://arqzero.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/LuciferDono/ArqZero"
  },
  "author": "Pranav Jadhav <arqzerohq@gmail.com> (https://github.com/LuciferDono)",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "highlight.js": "^11.11.1",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "openai": "^6.32.0",
    "react": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14"
  }
}
